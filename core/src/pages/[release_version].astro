---
import { getCollection, render } from 'astro:content';
import { getDatabase } from "../db.ts";
import { marked } from 'marked';
import Default from '../layouts/Default.astro'
import {DateTime} from "luxon";
import {DuckDBTimestampValue} from "@duckdb/node-api";
import {getAllVersions, getPrevAndNextVersion, getVersion} from "../repository";
import {getChangesByVersion} from "../repository/ChangeRepository.ts";

export async function getStaticPaths() {
    const entries = await getCollection('versions');
    return entries.map((entry) => ({
        params: { release_version: entry.data.release_version },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const release_version = entry.data.release_version;
const { Content } = await render(entry);

const version = await getVersion(release_version);
const changes = await getChangesByVersion(release_version);
const prevAndNextVersion = await getPrevAndNextVersion(release_version);


const markdownString = Object.entries(Object.groupBy(changes, (c) => c.type))
    .map(([type, items]) => {
        const itemLines = (items ?? [])
            .map(({ title, features }) =>
                features.length > 0
                    ? `- ${title}  \n${features.join(', ')}`
                    : `- ${title}`
            )
            .join('\n');
        return `## ${type}\n\n${itemLines}`;
    })
    .join('\n\n');

const changesHtml = await marked.parse(markdownString);

---
<Default title={entry.data.release_version}>
    <h1>Release: {release_version}</h1>
    <p>Released on {version.releaseDate?.toFormat("yyyy-MM-dd") ?? 'not yet released'}</p>
    <a href={version.url}>Go to GitHub release</a>
    <Content />
    <Fragment set:html={changesHtml} />

    <div class="release-nav">
        <wa-button
                href={prevAndNextVersion.prev ? `/${prevAndNextVersion.prev}/` : undefined}
                disabled={!prevAndNextVersion.prev || undefined}
        >
            Previous Release{prevAndNextVersion.prev ? `: ${prevAndNextVersion.prev}` : ''}
        </wa-button>
        <wa-button
                href={prevAndNextVersion.next ? `/${prevAndNextVersion.next}/` : undefined}
                disabled={!prevAndNextVersion.next || undefined}
        >
            Next Release{prevAndNextVersion.next ? `: ${prevAndNextVersion.next}` : ''}
        </wa-button>
        <wa-button
                href="/latest/"
        >
            Latest Release
        </wa-button>
    </div>
</Default>

<style>
    .release-nav {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
    }
</style>